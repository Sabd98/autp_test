{
  "openapi": "3.0.0",
  "info": {
    "title": "Portal AUTP API",
    "version": "1.0.0",
    "description": "REST API untuk sistem manajemen klaim asuransi padi Jasindo",
    "contact": {
      "name": "Sabda Avicenna",
      "email": "sabdaavicenna@fmri-research.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Local API Server"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "username": {"type": "string"},
                  "password": {"type": "string"}
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "token": {"type": "string"},
                    "user": {
                      "properties": {
                        "name": {"type": "string"}
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "Logged out successfully"}
        }
      }
    },
    "/claims": {
      "get": {
        "tags": ["Claims"],
        "summary": "List claims",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "default": 1}},
          {"name": "pageSize", "in": "query", "schema": {"type": "integer", "default": 10}},
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "status", "in": "query", "schema": {"type": "string"}},
          {"name": "cause", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Claims list"}
        }
      },
      "post": {
        "tags": ["Claims"],
        "summary": "Create claim",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "farmerName": {"type": "string"},
                  "farmerNIK": {"type": "string"},
                  "certificateNumber": {"type": "string"},
                  "plantingPeriod": {"type": "string", "enum": ["MT1", "MT2"]},
                  "plotVillage": {"type": "string"},
                  "plotDistrict": {"type": "string"},
                  "plotRegency": {"type": "string"},
                  "totalInsuredArea": {"type": "number"},
                  "failedLandArea": {"type": "number"},
                  "failureCause": {"type": "string"},
                  "submissionDate": {"type": "string", "format": "date"},
                  "compensationAmount": {"type": "integer"}
                },
                "required": ["farmerName", "farmerNIK", "certificateNumber", "plantingPeriod", "plotVillage", "plotDistrict", "plotRegency", "totalInsuredArea", "failedLandArea", "failureCause", "submissionDate"]
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Claim created"}
        }
      }
    },
    "/claims/{id}": {
      "get": {
        "tags": ["Claims"],
        "summary": "Get claim",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Claim details"}
        }
      },
      "put": {
        "tags": ["Claims"],
        "summary": "Update claim",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "claimStatus": {"type": "string", "enum": ["Pending", "Surveyed", "Approved", "Rejected"]},
                  "surveyorName": {"type": "string"},
                  "surveyDate": {"type": "string", "format": "date"},
                  "surveyNotes": {"type": "string"},
                  "compensationAmount": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Claim updated"}
        }
      },
      "delete": {
        "tags": ["Claims"],
        "summary": "Delete claim",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "204": {"description": "Claim deleted"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
